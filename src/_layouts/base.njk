<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">

  <title>{{ title or "Tanyaradzwa Mapuwei | Tech, Faith, Food, Music & Life" }}</title>

  <meta
    name="description"
    content="{{ description or "Step into Tanya’s little corner of the internet — a personal space for tech career stories, faith, food, music, travel, farming and the interesting things he loves." }}"
  >

  <meta name="robots" content="index, follow">

  <link rel="canonical" href="https://tanyaradzwa-mapuwei.co.za{{ page.url }}">

  <meta property="og:title" content="{{ title or "Tanyaradzwa Mapuwei | Tech, Faith, Food, Music & Life" }}">
  <meta
    property="og:description"
    content="{{ description or "Step into Tanya’s little corner of the internet — a personal space for tech career stories, faith, food, music, travel, farming and the interesting things he loves." }}"
  >
  <meta property="og:type" content="website">
  <meta property="og:url" content="https://tanyaradzwa-mapuwei.co.za{{ page.url }}">
  <meta property="og:image" content="https://tanyaradzwa-mapuwei.co.za/assets/images/profile/hero.jpg">

  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ title or "Tanyaradzwa Mapuwei | Tech, Faith, Food, Music & Life" }}">
  <meta
    name="twitter:description"
    content="{{ description or "Step into Tanya’s little corner of the internet — a personal space for tech career stories, faith, food, music, travel, farming and the interesting things he loves." }}"
  >
  <meta name="twitter:image" content="https://tanyaradzwa-mapuwei.co.za/assets/images/profile/hero.jpg">

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

  <link
    href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700;800;900&display=swap"
    rel="stylesheet"
  >

  <link
    rel="stylesheet"
    href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"
  >
  <link rel="icon" type="image/png" href="/assets/images/favicon.png">
  <link rel="stylesheet" href="/assets/css/style.css">
 
 <script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
 
</head>

<body{% if professionalPage %} class="professional-body"{% endif %}>
  <div class="grain"></div>
  {% include "nav.njk" %}
  <main>{{ content | safe }}</main>
  {% if not hideFooter %}{% include "footer.njk" %}{% endif %}
  
  <script src="/assets/js/script.js"></script>


  <script>
  if (window.netlifyIdentity) {
    window.netlifyIdentity.on("init", function (user) {
      if (!user) {
        window.netlifyIdentity.on("login", function () {
          document.location.href = "/admin/";
        });
      }
    });
  }
</script>
</body>
</html>
