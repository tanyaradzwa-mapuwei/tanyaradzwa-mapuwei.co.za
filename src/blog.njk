---
layout: base.njk
title: Blog | Tanyaradzwa Mapuwei
pagination:
  data: collections.post
  size: 100
  alias: posts
permalink: /blog/
---
<section class="page-hero section blog-hero">
  <p class="eyebrow">The blog</p>
  <h1>Faith, tech, food, music, travel and farming.</h1>
  <p class="lead">Let’s talk about IT, follow my journey and explore the little nitty-gritties of faith, food, music, travel, farming and the things I find interesting along the way.</p>
  <div class="blog-tools reveal" aria-label="Blog search and filters">
    <label class="search-box">
      <span>Search</span>
      <input id="blogSearch" type="search" placeholder="Search blog posts...">
    </label>
    <label class="select-box">
      <span>Filter topic</span>
      <select id="blogCategory">
        <option value="all">All topics</option>
        <option value="Tech Compass">Tech Compass</option>
        <option value="Music & Moments">Music & Moments</option>
        <option value="Tanya’s Table">Tanya’s Table</option>
        <option value="My Faith">My Faith</option>
        <option value="Out & About">Out & About</option>
        <option value="Rooted Living">Rooted Living</option>
      </select>
    </label>
    <label class="select-box">
      <span>Sort by date</span>
      <select id="blogSort">
        <option value="newest">Newest first</option>
        <option value="oldest">Oldest first</option>
      </select>
    </label>
  </div>
</section>
<section class="section blog-grid" id="blogGrid">
{% for post in collections.post | reverse %}
  <article class="blog-card reveal" data-title="{{ post.data.title | lower }}" data-category="{{ post.data.category }}" data-description="{{ post.data.description | lower }}" data-date="{{ post.data.date }}">
    <div class="pattern-card"><span>{{ post.data.category }}</span></div>
    <div>
      <p class="eyebrow">{{ post.data.category }}</p>
      <h2><a href="{{ post.url }}">{{ post.data.title }}</a></h2>
      <p>{{ post.data.description }}</p>
      <a class="text-link" href="{{ post.url }}">Read more →</a>
    </div>
  </article>
{% endfor %}
</section>
<p class="empty-state" id="blogEmpty" hidden>No blog posts match your search yet.</p>
